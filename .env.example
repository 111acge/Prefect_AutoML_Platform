# Prefect AutoML Platform 环境变量示例

# 数据库（默认 SQLite）
DATABASE_URL=sqlite+aiosqlite:///./data/db.sqlite

# LLM 意图解析（可选；未配置时自动降级到规则引擎）
# 支持 provider：kimi / deepseek / minimax / glm / openai / auto
LLM_PROVIDER=auto

KIMI_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
GLM_API_KEY=
OPENAI_API_KEY=

# 覆盖默认模型（留空则使用各提供商默认轻量模型）
DEFAULT_LLM_MODEL=

# GPU 加速（需 NVIDIA 驱动 + CUDA 运行时；默认自动检测）
# 设置为 false/0/no/off 可强制使用 CPU
USE_GPU=true
NUM_GPUS=1

# 指定可见 GPU，例如 "0" 或 "0,1"；设为空字符串 "" 可禁用 GPU
# CUDA_VISIBLE_DEVICES=0

# Prefect 编排（默认启用本地 Prefect Server + Flow Runner）
# 如需在局域网其他机器访问 Prefect UI，请把地址改为本机局域网 IP，例如：
# PREFECT_API_URL=http://192.168.1.5:4200/api
PREFECT_API_URL=http://localhost:4200/api
PREFECT_HOME=./.prefect
PREFECT_ENABLED=true

# 性能/稳定性优化开关（默认自动，一般无需配置；显式设置可覆盖自动决策）
# TRAIN_EVAL_SAMPLE_SIZE=0        # 0=跳过训练集评估；N=采样N行；留空=自动
# SHAP_MAX_SAMPLE_SIZE=0          # 0=跳过SHAP；N=最大采样N行；留空=自动
# PERMUTATION_IMPORTANCE_MAX_REPEATS=0  # 0=跳过；N=重复N次；留空=自动
# PERMUTATION_IMPORTANCE_SAMPLE_SIZE=N  # N=采样N行；留空=自动
# DATA_QUALITY_MAX_ROWS=N         # N=最多评估N行；0=强制全量；留空=自动
